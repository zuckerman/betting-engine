// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Match {
  id            String   @id
  homeTeam      String
  awayTeam      String
  date          DateTime
  homeGoals     Int?
  awayGoals     Int?
  result        String?  // "home_win" | "draw" | "away_win"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  predictions   Prediction[]

  @@index([date])
}

model Prediction {
  id            String   @id @default(cuid())
  matchId       String
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  homeWinProb   Float
  drawProb      Float
  awayWinProb   Float
  
  homeOdds      Float
  drawOdds      Float
  awayOdds      Float
  
  predictedResult String  // "home_win" | "draw" | "away_win"
  
  createdAt     DateTime @default(now())
  
  @@index([matchId])
  @@index([createdAt])
}

model Performance {
  id            String   @id @default(cuid())
  totalMatches  Int
  correctPredictions Int
  accuracy      Float
  totalProfit   Float
  roi           Float
  calculatedAt  DateTime @default(now())
}
