// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Experiment {
  id            String   @id @default(uuid())
  name          String   @unique // "EPL_2026_V1", "WC_2026_V1"
  sport         String   @default("football")
  competition   String   // "EPL", "WorldCup", etc
  status        String   @default("active") // "active" / "complete"
  
  startDate     DateTime @default(now())
  endDate       DateTime?
  
  predictions   Prediction[]
  bets          Bet[]
  bankroll      Bankroll?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([status])
  @@index([competition])
}

model Bankroll {
  id                String   @id @default(uuid())
  experimentId      String   @unique
  experiment        Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  
  startingBalance   Float
  currentBalance    Float
  peakBalance       Float
  
  updatedAt         DateTime @default(now()) @updatedAt
  
  @@index([experimentId])
}

model ModelVersion {
  id                String   @id @default(uuid())
  name              String   // "poisson_v1", "xgboost_v1", etc
  version           String   // "1.0", "1.1", etc
  description       String?
  
  predictions       Prediction[]
  bets              Bet[]
  
  createdAt         DateTime @default(now())
  
  @@unique([name, version])
  @@index([name])
}

model GlobalBankroll {
  id                String   @id @default(uuid())
  totalBalance      Float
  peakBalance       Float
  updatedAt         DateTime @default(now()) @updatedAt
}

model Prediction {
  id                 String   @id @default(uuid())

  // Experiment tracking
  experimentId       String
  experiment         Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  // Model tracking
  modelId            String
  model              ModelVersion @relation(fields: [modelId], references: [id], onDelete: Cascade)

  // Competition tracking (for regime analysis)
  competition        String   @default("epl")
  season             String?

  // Match identification
  fixtureId          String?
  matchId            String
  homeTeam           String?
  awayTeam           String?
  league             String?

  // Market & selection
  market             String
  selection          String

  // Probabilities (all 0-1)
  modelProbability   Float
  impliedProbability Float
  externalProbability Float?
  edge               Float
  ev                 Float?
  signalQuality      String   @default("NORMAL")
  modelVersion       String   @default("v1")

  // Betting data
  oddsTaken          Float
  closingOdds        Float?
  stake              Float    @default(1)

  // Result
  result             ResultStatus?

  // Timestamps
  placedAt           DateTime
  kickoffAt          DateTime?
  settledAt          DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([experimentId])
  @@index([modelId])
  @@index([matchId])
  @@index([competition])
  @@index([season])
  @@index([placedAt])
  @@index([kickoffAt])
  @@index([result])
}

enum ResultStatus {
  WIN
  LOSS
  VOID
}

model Bet {
  id                String   @id @default(uuid())
  
  // Experiment + Model tracking
  experimentId      String
  experiment        Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  
  modelId           String
  model             ModelVersion @relation(fields: [modelId], references: [id], onDelete: Cascade)
  
  predictionId      String?
  
  // Match + market
  matchId           String
  market            String   // "home_win", "draw", "away_win", "over_2.5", etc
  
  // Odds & stake
  oddsTaken         Float
  stake             Float
  impliedProbTaken  Float    // 1 / odds_taken
  
  // Allocation weights
  modelWeight       Float    @default(1.0)
  marketWeight      Float    @default(1.0)
  
  // Shadow bets (tracking skipped predictions)
  isShadow          Boolean  @default(false)
  
  // Result & CLV
  result            ResultStatus?
  closingOdds       Float?
  clv               Float?   // (closing_odds / odds_taken) - 1
  
  // Settlement
  settled           Boolean  @default(false)
  
  // Timestamps
  placedAt          DateTime @default(now())
  settledAt         DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([experimentId])
  @@index([modelId])
  @@index([matchId])
  @@index([isShadow])
  @@index([result])
  @@index([settled])
  @@index([placedAt])
}

model OddsSnapshot {
  id        String   @id @default(uuid())
  matchId   String
  odds      Float
  timestamp DateTime @default(now())

  @@index([matchId])
  @@index([timestamp])
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique

  // Billing
  isPro       Boolean  @default(false)
  stripeId    String?  @unique

  // Onboarding
  onboarded   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
}

model ShadowBet {
  id                 String   @id @default(cuid())
  
  // Regime tracking
  competition        String   @default("epl")
  season             String?
  
  // Why was this skipped?
  skipReason         String   // "low_ev", "below_edge_threshold", "high_variance", "manual_filter", etc
  
  // Match identification
  matchId            String
  homeTeam           String?
  awayTeam           String?
  league             String?
  
  // Market & selection
  market             String   // "over_2.5", "btts", etc
  selection          String   // "over", "yes", etc
  
  // Probabilities (what would have been)
  modelProbability   Float
  impliedProbability Float
  edge               Float
  ev                 Float?
  
  // Odds (if we had taken it)
  oddsTaken          Float?
  closingOdds        Float?   // actual closing odds
  
  // Result (if it had been taken)
  result             ResultStatus?  // WIN / LOSS / VOID
  clvWouldHaveBeen   Float?    // closing_odds - odds_taken (for analysis)
  
  // Timestamps
  analyzedAt         DateTime  // when we considered it
  kickoffAt          DateTime?
  settledAt          DateTime?
  
  createdAt          DateTime  @default(now())
  
  @@index([matchId])
  @@index([competition])
  @@index([skipReason])
  @@index([analyzedAt])
  @@index([kickoffAt])
  @@index([result])
}

model DailySnapshot {
  id                String   @id @default(uuid())
  
  // Experiment + Regime
  experimentId      String
  competition       String   @default("epl")
  season            String?
  
  date              String   // YYYY-MM-DD
  totalBets         Int
  rollingClv        Float
  highQualityClv    Float    @default(0)
  normalQualityClv  Float    @default(0)
  beatRate          Float
  expectedProfit    Float
  actualProfit      Float
  divergence        Float
  systemState       String   // GREEN, AMBER, RED
  timestamp         DateTime @default(now())

  @@index([experimentId])
  @@index([date])
  @@index([competition])
  @@index([season])
  @@index([timestamp])
}

