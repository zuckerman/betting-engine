// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Prediction {
  id                 String   @id @default(uuid())

  // Match identification
  fixtureId          String?  @unique
  matchId            String
  homeTeam           String?
  awayTeam           String?
  league             Int?

  // Market & selection
  market             String   // "over_2.5", "btts", etc
  selection          String   // "over", "yes", etc

  // Probabilities (all 0-1)
  modelProbability   Float
  impliedProbability Float   // from odds
  externalProbability Float?  // from Sportmonks, etc
  edge               Float    // modelProb - impliedProb

  // Betting data
  oddsTaken          Float
  closingOdds        Float?   // odds at kickoff
  stake              Float    @default(1)

  // Result
  result             ResultStatus?  // WIN / LOSS / VOID

  // Timestamps
  placedAt           DateTime
  kickoffAt          DateTime?
  settledAt          DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([matchId])
  @@index([placedAt])
  @@index([kickoffAt])
  @@index([result])
}

enum ResultStatus {
  WIN
  LOSS
  VOID
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique

  // Billing
  isPro       Boolean  @default(false)
  stripeId    String?  @unique

  // Onboarding
  onboarded   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
}
